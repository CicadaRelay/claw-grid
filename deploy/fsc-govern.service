[Unit]
Description=FSC-Mesh Governance Sidecar (Rust)
After=network.target redis.service
Wants=redis.service

[Service]
Type=simple
ExecStart=/usr/local/bin/fsc-govern --redis redis://:fsc-mesh-2026@127.0.0.1:6379
Restart=always
RestartSec=3
MemoryMax=64M

# 安全加固
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true

# 日志
StandardOutput=journal
StandardError=journal
SyslogIdentifier=fsc-govern

[Install]
WantedBy=multi-user.target
